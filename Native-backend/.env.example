# Provider switch: "azure" or "local"
PROVIDER=azure

# Azure Speech Services
AZURE_SPEECH_KEY=your_key_here
AZURE_SPEECH_REGION=westeurope

# Azure AI Foundry
AZURE_VOICELIVE_ENDPOINT=https://your-project.services.ai.azure.com/
AZURE_VOICELIVE_API_KEY=your_key_here
AZURE_VOICELIVE_MODEL=gpt-4o-mini

# Azure AI Foundry - Grok 4.3
AZURE_GROK_ENDPOINT=https://your-project.openai.azure.com/openai/v1
AZURE_GROK_API_KEY=your_key_here
AZURE_GROK_DEPLOYMENT_NAME=grok-4.3

# Azure Translator
AZURE_TRANSLATOR_ENDPOINT=https://your-project.services.ai.azure.com/translator/text/
AZURE_TRANSLATOR_KEY=your_key_here

# Azure AI Search - Foundry IQ
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your_key_here
AZURE_SEARCH_INDEX=native-knowledge

# JWT Secret
JWT_SECRET_KEY=your_secret_key_here
